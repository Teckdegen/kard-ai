# ═══════════════════════════════════════════════════════════════════════════════
# KARD SDK — Environment Configuration
# All variables below are REQUIRED for production onchain operation.
# Copy this file to .env and fill in real values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Chain Configuration (REQUIRED) ─────────────────────────────────────────
# Filecoin Mainnet: CHAIN_ID=314, RPC_URL=https://api.node.glif.io/rpc/v1
# Filecoin Calibration (testnet): CHAIN_ID=314159, RPC_URL=https://api.calibration.node.glif.io/rpc/v1
CHAIN_ID=314
RPC_URL=https://api.node.glif.io/rpc/v1

# ─── Alkahest Escrow Contracts (REQUIRED) ───────────────────────────────────
# Deploy Alkahest contracts or use existing deployment addresses.
# See: https://github.com/arkhai-labs/alkahest
ALKAHEST_ESCROW=0x...
ALKAHEST_ARBITER_TRUSTED_PARTY=0x...

# ─── Filecoin Pin — IPFS Pinning Service API (REQUIRED) ─────────────────────
# All protocol artifacts (agreements, proofs, verdicts, receipts) are pinned.
# Providers: web3.storage, Storacha, or any IPFS Pinning Service API endpoint.
FILECOIN_PIN_ENDPOINT=https://api.web3.storage/pins
FILECOIN_PIN_TOKEN=your-bearer-token-here
FILECOIN_PIN_POLL_MS=2000
FILECOIN_PIN_TIMEOUT_MS=120000

# ─── Agent Private Keys (REQUIRED) ──────────────────────────────────────────
# Fund these wallets with FIL on your target chain.
# NEVER commit real private keys to version control.
BUYER_PK=0x...
SELLER_PK=0x...
ARBITER_PK=0x...

# ─── Smart Account / Account Abstraction (OPTIONAL) ─────────────────────────
# Enable ERC-4337 smart account execution for agents.
# AA_SMART_ACCOUNT=0x...
# AA_BUNDLER_URL=https://bundler.example/rpc
# AA_ENTRYPOINT=0x0000000071727De22E5E9d8BAf0edAc6f37da032

# ─── Escrow Options (OPTIONAL) ──────────────────────────────────────────────
# ESCROW_TOKEN=0x0000000000000000000000000000000000000000  # zero = native FIL
# DISPUTE_WINDOW_SECONDS=3600
# EXPIRATION_BUFFER_SECONDS=7200

# ─── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=info
